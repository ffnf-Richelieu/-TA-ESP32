#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>

// --- KONFIGURASI JARINGAN & API ---
const char* ssid = "Test";
const char* password = "hahahaha";
const String urlControl = "http://10.224.51.67:8000/api/control";
const String urlSensor = "http://10.224.51.67:8000/api/sensor";

// Variabel Global untuk menyimpan JSON Sensor dari Mega
String latestSensorJson = "";

// Variabel Simulasi Fuzzy (State Machine)
int fuzzySimulationStep = 0; 

// Handle untuk RTOS Task
TaskHandle_t TaskWebHandle;
TaskHandle_t TaskMegaHandle;

// ===============================================================
// PROTOTIPE FUNGSI
// ===============================================================
void TaskKomunikasiWeb(void *pvParameters);
void TaskKomunikasiMega(void *pvParameters);

void setup() {
  Serial.begin(115200);
  Serial2.begin(9600); // Komunikasi ke Mega (TX2=17, RX2=16 pada ESP32)

  Serial.println("\n\n===========================================");
  Serial.println("   STARTING ESP32 RTOS - BIOPOND MANAGER   ");
  Serial.println("===========================================\n");

  WiFi.begin(ssid, password);
  Serial.print("[WiFi] Menghubungkan ke jaringan ");
  Serial.print(ssid);
  
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\n[WiFi] Berhasil Terhubung! IP Address: " + WiFi.localIP().toString());
  Serial.println("-------------------------------------------\n");

  // Membuat Task FreeRTOS
  xTaskCreatePinnedToCore(TaskKomunikasiWeb, "TaskWeb", 10000, NULL, 1, &TaskWebHandle, 0); // Core 0
  xTaskCreatePinnedToCore(TaskKomunikasiMega, "TaskMega", 10000, NULL, 1, &TaskMegaHandle, 1); // Core 1
}

void loop() {
  // Dalam FreeRTOS ESP32, loop() kosong. Semua logika diatur oleh Task.
}

// ===============================================================
// TASK 1: KOMUNIKASI WEB & PENGAMBILAN KEPUTUSAN FUZZY (CORE 0)
// ===============================================================
void TaskKomunikasiWeb(void *pvParameters) {
  for (;;) {
    if (WiFi.status() == WL_CONNECTED) {
      HTTPClient http;

      // -------------------------------------------------
      // A. MINTA DATA KONTROL DARI WEB (GET)
      // -------------------------------------------------
      http.begin(urlControl);
      int httpCodeGET = http.GET();
      
      if (httpCodeGET == 200) {
        String payload = http.getString();
        
        JsonDocument docWeb;
        deserializeJson(docWeb, payload);
        
        bool isManual = docWeb["is_manual"];
        
        Serial.println("\n>>> SIKLUS KONTROL (TIAP 5 DETIK) <<<");
        Serial.print("[WEB - GET] Data diterima. Mode Operasional saat ini: ");
        Serial.println(isManual ? "MANUAL (USER OVERRIDE)" : "OTOMATIS (FUZZY LOGIC)");
        
        // Dokumen yang akan dilempar ke Mega
        JsonDocument docToMega;
        JsonArray mistToMega = docToMega["mist"].to<JsonArray>();

        if (isManual) {
          // ==========================================
          // MODE MANUAL: AMBIL DATA DARI WEB
          // ==========================================
          docToMega["fan"] = docWeb["fan"];
          for(int i=0; i<6; i++) {
            mistToMega.add(docWeb["mist"][i]);
          }
          Serial.println("[KONTROL] Mengabaikan perhitungan Fuzzy. Menggunakan input dari Web.");
          
        } else {
          // ==========================================
          // MODE OTOMATIS: SIMULASI FUZZY LOGIC
          // ==========================================
          Serial.println("[KONTROL] Menggunakan perhitungan Fuzzy mandiri...");
          
          int fuzzyFanResult = 0; 
          int fuzzyMistResult[6] = {0, 0, 0, 0, 0, 0}; 

          // Simulasi Rolling: Step 0-5 Nyalakan Mist 1-6 bergantian. Step 6 Kipas nyala.
          if (fuzzySimulationStep >= 0 && fuzzySimulationStep <= 5) {
            fuzzyMistResult[fuzzySimulationStep] = 1; // Nyalakan 1 mist sesuai step
            Serial.printf("[FUZZY] Memutuskan: Mist Rak %d ON, Kipas OFF\n", fuzzySimulationStep + 1);
          } 
          else if (fuzzySimulationStep == 6) {
            fuzzyFanResult = 80; // Kipas nyala 80%
            Serial.println("[FUZZY] Memutuskan: Semua Mist OFF, Kipas ON (80%)");
          }

          // Masukkan hasil fuzzy ke dokumen untuk Mega
          docToMega["fan"] = fuzzyFanResult;
          for(int i=0; i<6; i++) {
            mistToMega.add(fuzzyMistResult[i]);
          }

          // Update step simulasi (0 -> 1 -> 2 -> 3 -> 4 -> 5 -> 6 -> kembali ke 0)
          fuzzySimulationStep++;
          if (fuzzySimulationStep > 6) fuzzySimulationStep = 0;
        }

        // ==========================================
        // KIRIM PERINTAH KE ARDUINO MEGA
        // ==========================================
        String jsonTerkirim;
        serializeJson(docToMega, jsonTerkirim);
        
        Serial.print("[UART - TX] Mengirim perintah ke Mega: ");
        Serial.println(jsonTerkirim);
        
        // Kirim via Serial2 ke Mega
        Serial2.println(jsonTerkirim); 

      } else {
        Serial.printf("[WEB - GET] Gagal mengambil data kontrol. HTTP Code: %d\n", httpCodeGET);
      }
      http.end();

      // -------------------------------------------------
      // B. KIRIM DATA SENSOR KE WEB (POST)
      // -------------------------------------------------
      if (latestSensorJson != "") {
        http.begin(urlSensor);
        http.addHeader("Content-Type", "application/json");
        
        Serial.print("[WEB - POST] Mengunggah data sensor ke server... ");
        int httpCodePOST = http.POST(latestSensorJson);
        
        if(httpCodePOST == 201) {
            Serial.println("BERHASIL! (HTTP 201)");
        } else {
            Serial.printf("GAGAL! (HTTP Code: %d)\n", httpCodePOST);
        }
        http.end();
      } else {
        Serial.println("[WEB - POST] Belum ada data sensor dari Mega. Lewati unggahan.");
      }
    } else {
      Serial.println("[WiFi] Koneksi terputus! Sedang mencoba menyambungkan ulang...");
    }

    // Jeda Task selama 5 detik
    vTaskDelay(pdMS_TO_TICKS(5000));
  }
}

// ===============================================================
// TASK 2: MENDENGARKAN DATA DARI ARDUINO MEGA (CORE 1)
// ===============================================================
void TaskKomunikasiMega(void *pvParameters) {
  for (;;) {
    if (Serial2.available()) {
      String incomingJson = Serial2.readStringUntil('\n');
      incomingJson.trim();

      if (incomingJson.startsWith("{") && incomingJson.endsWith("}")) {
        // Simpan ke memori global untuk diunggah oleh TaskWeb
        latestSensorJson = incomingJson;
        
        Serial.println("\n[UART - RX] Data Sensor Diterima dari Mega!");
        Serial.print("            Payload: ");
        Serial.println(incomingJson);
      }
    }
    
    // Memberikan jeda waktu untuk Core 1 agar tidak Overload (Wajib dalam RTOS)
    vTaskDelay(pdMS_TO_TICKS(50)); 
  }
}